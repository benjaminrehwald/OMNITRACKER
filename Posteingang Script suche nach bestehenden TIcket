'║ @summary:       filling the activeRequest with information
'║ @last_change:   2014-08-06
'║ @param objreq:  
'╚═══════════════════════════════════════════════════════════════════════════════

Sub FillTicketWithInformation(objReq, strTicketProcess)

    Dim objMails

    If arrTicket(0) <> 0 Then 'only when a related ticket was found
	Set objMails = objReq.Fields("RelatedEmails").TValue
	objMails.Prefetch()
	objMails.AddExisting ActiveRequest
	Set objReq.Fields("RelatedEmails").TValue = objMails
	If strTicketProcess = "C" Then 'CallTicket 'SREQ-61508
if false then	    
	    If Not objReq.Fields("MainTicket").IsNull Then
		Dim objMT
		Set objMT = objReq.Fields("MainTicket").TValue
		Set objMails = objMT.Fields("RelatedEmails").TValue
		objMails.Prefetch()
		objMails.AddExisting ActiveRequest
		Set objMT.Fields("RelatedEmails").TValue = objMails
		objMT.Saveex 7 + 256
	    End If
End If
    
	End If
	
    End If
End Sub 'FillTicketWithInformation
