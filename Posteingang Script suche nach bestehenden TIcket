'║ @summary:           Get Ticket with the subject line and search for the number
'║ @last_change:       2014-08-06
'║ @param strsubject:  ActiveRequest.Fields("Subject").Value
'║ @returns:           found ticket with the number in the subject
'╚═══════════════════════════════════════════════════════════════════════════════

Function GetTicket(strSubject, byRef strTicketProcess)

    If bolLogging Then LogMessage "GetTicket " & strSubject

    Dim bolRecursive
    Dim intCount, intOutput, strPattern, strIncident, strProblem, strChange, strUCT, strSR, strCall
    Dim regEx, Match, Matches, regExIncident, regExProblem, regExChange, regExUCT, regExServiceRequest, regExCall', strTicketProcess
    Dim bolError: bolError = False

    intCount = 0
    intOutput = 0

    strPattern = "#Ticket (I|P|RFC|X|SR|SUB|C)-([0-9]+)#"

    'Search for Ticketnumber in Subject line...
    Set regEx = New RegExp
    regEx.Pattern = CStr(strPattern)
    regEx.IgnoreCase = True
    bolRecursive = False
    If regEx.Test(strSubject) Then
	Dim strNumber, objFolder, objFilter
	Set Matches = regEx.Execute(strSubject)
	Set Match = Matches(0)
	strTicketProcess = Match.SubMatches(0) 'String "I"
	strNumber = Match.SubMatches(1) 'The Number 

	If strTicketProcess = "I" Then
	    If bolLogging Then LogMessage "  This is about an Incident"
	    Set objFolder = ActiveSession.RequestFolders("Incidents")
	ElseIf strTicketProcess = "SR" Then
	    If bolLogging Then LogMessage "  This is about a ServiceRequest"
	    Set objFolder = ActiveSession.RequestFolders("RequestFulfillment")
	ElseIf strTicketProcess = "P" Then
	    If bolLogging Then LogMessage "  This is about a Problem"
	    Set objFolder = ActiveSession.RequestFolders("Problems")
	ElseIf strTicketProcess = "RFC" Then
	    If bolLogging Then LogMessage "  This is about an RFC"
	    Set objFolder = ActiveSession.RequestFolders("RFCs")
	ElseIf strTicketProcess = "SUB" Then
	    If bolLogging Then LogMessage "  This is about an External Ticket"
	    Set objFolder = ActiveSession.RequestFolders("ExternalTickets")
	ElseIf strTicketProcess = "C" Then
	    If bolLogging Then LogMessage "  This is about a Call Ticket"
	    Set objFolder = ActiveSession.RequestFolders("CallTickets")
	    bolRecursive = True
	Else
	    'Ticket matches regular expression for strPattern, but not a regular expression for process
	    GetTicket = Array(0, 0)
	    Exit Function
	End If

	Set objFilter = objFolder.MakeFilter

	On Error Resume Next

	objFilter.UserField("Number") = CLng(strNumber)
	If Err.Number <> 0 Then 
		bolError = True
	End If
	On Error Goto 0

	If Not bolError Then
		Dim objTickets
		Set objTickets = objFolder.Search(objFilter, bolRecursive)

		intCount = objTickets.Count
		If intCount > 0 Then intOutput = objTickets(0).UniqueId
	End If	
    End If

    GetTicket = Array(intCount, intOutput)
End Function 'GetTicket
