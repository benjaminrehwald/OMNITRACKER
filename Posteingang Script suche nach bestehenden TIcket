Option Explicit

Const bolLogging = False

If bolLogging Then LogMessage "After Creation: Check subject line if there is an existing ticket in the database"

'Check the Email attributes SenderAddress and ReplyToAddress for any known email-addresses in the customer database
Dim strSubject, arrTicket

strSubject = ActiveRequest.Fields("Subject").Value
Dim strTicketProcess
arrTicket = GetTicket(strSubject, strTicketProcess)

If arrTicket(0) Then
    If bolLogging Then LogMessage ActiveSession.GetSystemParameter("ITSM_Global_Constants_and_Variables", "STR_Text_ReftoexistingTicket")

    Dim objRequest
    Set objRequest = ActiveSession.GetRequestByUniqueId(arrTicket(1))

    FillTicketWithInformation objRequest, strTicketProcess

    If arrTicket(0) > 1 Then
	Dim secs, strMultiple
	strMultiple = ActiveSession.GetSystemParameter("ITSM_Global_Constants_and_Variables", "STR_Text_FoundMultipleTickets")

	Set secs = objRequest.Fields("Answers").TValue
	secs.Add objRequest.Application.ConvertPlainToFormattedText(strMultiple)
	Set objRequest.Fields("Answers").TValue = secs
    End If

    objRequest.SaveEx 7 + 256 'no permissions, no privileges, do not validate input
    
   '05.07.2018 by schraut, requested by Rehwald : information mail if target already closed
    If strTicketProcess = "I" Or strTicketProcess = "SR" Or strTicketProcess = "C" Then
	Set objRequest = ActiveSession.GetRequestByUniqueId(objRequest.UniqueId)
	Dim strStateAlias
	strStateAlias = ""
	If objRequest.Fields("State").Value <> "" Then	    
	    strStateAlias = objRequest.Fields("State").TValue.alias
	End If
	If strStateAlias = "Closed" Or strStateAlias = "Rejected" Then
	    Dim objOEmail
	    Set objOEmail = ActiveRequest.GenerateEmail("ReplyTicketClosed")'Ex("ReplyTicketClosed", 0)'1) 'AsEmail
	    if false then
	    Dim objReplyEmail
	    Set objReplyEmail = objOEmail.Reply(True, True)
	    objReplyEmail.PlainTextBody = "Danke für Ihre Email." & vbCrLf & "Leider ist das zugehörige Ticket bereits abgeschlossen/abgewiesen und Ihre Email kann somit leider nicht mehr berücksichtigt werden!" & _
 vbCrLf & "/" & vbCrLf & "Thanks for your Email! Unfortunal the associated ticket is already closed/rejected and you email will no be taken into account!" & vbCrLf & vbCrLf & objReplyEmail.PlainTextBody
    	    end if 
    	    objOEmail.send
    	    Dim objreplyobj, objmails2
     	    Set objReplyObj = objoEmail.loggedemail
     	    Set objMails2 = objRequest.Fields("RelatedEmails").TValue
     	    objMails2.Prefetch()
     	    objMails2.AddExisting objReplyObj
	    Set objRequest.Fields("RelatedEmails").TValue = objmails2
	    objRequest.SaveEx 7 + 256 'no permissions, no privileges, do not validate input
	ElseIf strStateAlias = "Solved" And strTicketProcess = "I" Then
	    on error resume next
	    objRequest.Fields("State").Value = "In progress"
	     objRequest.SaveEx 7 + 256 'no permissions, no privileges, do not validate input
	ElseIf strStateAlias = "Solved" And strTicketProcess = "SR" Then
	    On Error Resume Next
	    If objRequest.Fields("AffectedService").isnull then
	    	objRequest.Fields("State").Value = "In progress"
		objRequest.SaveEx 7 + 256 'no permissions, no privileges, do not validate input
	    ElseIf objRequest.Fields("AffectedService").TValue.Fields("RequestType").Value = "" Then
		objRequest.Fields("State").Value = "In progress"
		objRequest.SaveEx 7 + 256 'no permissions, no privileges, do not validate input
	    ElseIf objRequest.Fields("AffectedService").TValue.Fields("RequestType").TValue.alias <> "AccessManagement" Then
		objRequest.Fields("State").Value = "In progress"
		objRequest.SaveEx 7 + 256 'no permissions, no privileges, do not validate input
	    End If
	ElseIf strStateAlias = "Solved" And strTicketProcess = "C" Then
	    On Error Resume Next
	    
	    If Not objRequest.Fields("MainTicket").IsNull Then
		Dim objMTi, strMTiFolderAlias		
		Set objMTi = objRequest.Fields("MainTicket").TValue
		strMTiFolderAlias = objMTi.RequestFolder.alias
    	    	If strMTiFolderAlias = "Incidents" Then
		    On Error Resume Next
		    objMTi.Fields("State").Value = "In progress"
		    objMTi.SaveEx 7 + 256 'no permissions, no privileges, do not validate input

		ElseIf strMTiFolderAlias = "RequestFulfillment" Then
		    On Error Resume Next
		    If objMTi.Fields("AffectedService").IsNull Then
			objMTi.Fields("State").Value = "In progress"
			objMTi.SaveEx 7 + 256 'no permissions, no privileges, do not validate input
		    ElseIf objMTi.Fields("AffectedService").TValue.Fields("RequestType").Value = "" Then
			objMTi.Fields("State").Value = "In progress"
			objMTi.SaveEx 7 + 256 'no permissions, no privileges, do not validate input
		    ElseIf objMTi.Fields("AffectedService").TValue.Fields("RequestType").TValue.alias <> "AccessManagement" Then
			objMTi.Fields("State").Value = "In progress"
			objMTi.SaveEx 7 + 256 'no permissions, no privileges, do not validate input
	    	    End If
		End If
		
	    End If
	    
	End If
	
    End If
    
End If
